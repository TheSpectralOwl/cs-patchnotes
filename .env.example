# .env.example — committed secret-NAME contract (D-08). Names only, NO values.
#
# Real values live ONLY in a git-ignored `.env` on the box / in GitHub Secrets
# (Phase 1). Copy this file to `.env` and fill in the values there — never here.
# `.gitignore` ignores `.env` and `.env.*` while un-ignoring this `.env.example`.

# --- Secrets (required at runtime; injected via compose env_file/${VAR}) ---

# Meilisearch admin/master key — required in Phase 0. Generate a strong random
# key, e.g. `openssl rand -base64 32`. Stays server-side only; never reaches a client.
MEILI_MASTER_KEY=

# Cloudflare remote-managed (token) tunnel — required on the VPS in Phase 0.
# From Cloudflare Zero Trust -> Tunnels -> tunnel token.
TUNNEL_TOKEN=

# Anthropic API key — documented now, first USED in Phase 3 (D-09). May be left
# blank in Phase 0. From the Anthropic Console.
ANTHROPIC_API_KEY=

# --- Non-secret defaults (safe to keep as-is) ---

# Fastify listen port inside the api container.
PORT=3000

# Internal Meilisearch URL reached by the api over the compose network.
MEILI_HOST=http://meili:7700
