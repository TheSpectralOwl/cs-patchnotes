# .env.example
#

# --- Secrets (required at runtime; injected via compose env_file/${VAR}) ---

# Meilisearch admin/master key. Generate a strong random
# key, e.g. `openssl rand -base64 32`. Stays server-side only; never reaches a client.
MEILI_MASTER_KEY=

# Cloudflare remote-managed (token) tunnel 
# From Cloudflare Zero Trust -> Tunnels -> tunnel token.
TUNNEL_TOKEN=

# Anthropic API key 
ANTHROPIC_API_KEY=

# --- Non-secret defaults (safe to keep as-is) ---

# Fastify listen port inside the api container.
PORT=3000

# Internal Meilisearch URL reached by the api over the compose network.
MEILI_HOST=http://meili:7700
