#!/usr/bin/env sh
# Strip ephemeral planning-cycle plan scopes from the commit subject.
#
# GSD-style tooling writes subjects like "feat(02-04): add X" where "02-04" is a
# phase/plan identifier. Planning is renumberable and gitignored; the git history
# is durable. This hook rewrites "type(NN-NN): subject" -> "type: subject" (keeping
# any conventional-commit "!" breaking-change marker) so plan IDs never enter
# permanent history. Legitimate package scopes like "feat(pipeline):" are untouched
# because only the exact NN-NN plan-id pattern is matched.
#
# It auto-strips (rather than rejecting) so autonomous executor commits never fail
# mid-run; the normalized subject is what lands.

msg_file="$1"
[ -f "$msg_file" ] || exit 0

tmp="$(mktemp)" || exit 0
sed -E '1 s/^([a-z]+)\(([0-9]{2}-[0-9]{2})\)(!?): /\1\3: /' "$msg_file" > "$tmp" && mv "$tmp" "$msg_file"

exit 0
