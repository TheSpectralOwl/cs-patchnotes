{
  "name": "cs-patchnotes",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "npm test --workspaces --if-present",
    "build": "npm run build -w packages/shared && npm run build --workspaces --if-present",
    "build:archive": "npm run build -w @cs-patchnotes/archive",
    "build:cloudflare": "node pipeline/build-cloudflare.cjs",
    "test:pipeline": "node --test pipeline/test/*.test.cjs",
    "verify:corpus": "node pipeline/verify.cjs",
    "update:steam": "node pipeline/update-steam.cjs",
    "dev": "npm run dev -w packages/api",
    "check:secrets": "bash scripts/check-no-secrets.sh",
    "check:meili-port": "bash scripts/check-no-meili-port.sh",
    "check:web-bundle": "bash scripts/check-no-meili-key-in-web.sh",
    "check:infra": "npm run check:secrets && npm run check:meili-port && npm run check:web-bundle"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4",
    "typescript": "^5.9",
    "vitest": "^3"
  }
}
